# --------------------------------------------------------------------
# LOCAL DEVELOPMENT vs PRODUCTION TOGGLE
# --------------------------------------------------------------------
# For LOCAL DEV (default): Leave USE_AZURE unset or set to false
#   - Uses SQLite (app.db) for database
#   - Stores uploads locally in /app/uploads/
#   - No Azure credentials needed
#
# For PRODUCTION (Azure): Set USE_AZURE=true
#   - Uses Azure SQL Database (requires SQL_SERVER, etc.)
#   - Stores uploads in Azure Blob Storage
#   - Requires all Azure credentials below

USE_AZURE=false

# For SQLite (dev) — optional, defaults to app.db
DB_PATH=app.db

# --------------------------------------------------------------------
# AZURE SQL DATABASE (production only)
# --------------------------------------------------------------------
SQL_SERVER=your-server-name.database.windows.net
SQL_DATABASE=enrollmentdb
SQL_USERNAME=your-sql-admin
SQL_PASSWORD=your-password

# --------------------------------------------------------------------
# AZURE BLOB STORAGE (production only)
# --------------------------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_BLOB_CONTAINER=documents

# --------------------------------------------------------------------
# APPLICATION INSIGHTS (production only)
# --------------------------------------------------------------------
APPINSIGHTS_INSTRUMENTATIONKEY=your-instrumentation-key

# --------------------------------------------------------------------
# FLASK
# --------------------------------------------------------------------
FLASK_SECRET_KEY=your-random-secret-key
FLASK_ENV=development